<idea-plugin>
    <id>com.github.hoshinofw.multiversion</id>
    <name>Version Patcher Support</name>
    <vendor>HoshinOfW</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Multiversion" displayType="BALLOON"/>
        <daemon.highlightInfoFilter implementation="com.github.hoshinofw.multiversion.idea_plugin.OverwriteDuplicateClassHighlightFilter"/>
        <daemon.highlightInfoFilter implementation="com.github.hoshinofw.multiversion.idea_plugin.ShadowVersionHighlightFilter"/>
        <gotoDeclarationHandler implementation="com.github.hoshinofw.multiversion.idea_plugin.PatchedSrcGotoDeclarationHandler"/>
        <psi.referenceContributor language="JAVA" implementation="com.github.hoshinofw.multiversion.idea_plugin.DescriptorReferenceContributor"/>
        <localInspection language="JAVA"
                         displayName="Descriptor annotation validation"
                         groupName="Multiversion"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.github.hoshinofw.multiversion.idea_plugin.DescriptorAnnotationInspection"/>
        <applicationService serviceImplementation="com.github.hoshinofw.multiversion.idea_plugin.MultiversionSettings"/>
        <applicationConfigurable parentId="tools"
                                 instance="com.github.hoshinofw.multiversion.idea_plugin.MultiversionConfigurable"
                                 id="com.github.hoshinofw.multiversion.settings"
                                 displayName="Multiversion"/>
        <renamePsiElementProcessor implementation="com.github.hoshinofw.multiversion.idea_plugin.MultiversionRenameProcessor"
                                   order="first"/>
        <findUsagesHandlerFactory implementation="com.github.hoshinofw.multiversion.idea_plugin.PatchedSrcFindUsagesHandlerFactory"
                                   language="JAVA"/>
        <postStartupActivity implementation="com.github.hoshinofw.multiversion.idea_plugin.MultiversionProjectStartup"/>
    </extensions>

    <applicationListeners>
        <listener class="com.github.hoshinofw.multiversion.idea_plugin.MultiversionOnSaveListener"
                  topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"/>
    </applicationListeners>

    <projectListeners>
        <listener class="com.github.hoshinofw.multiversion.idea_plugin.PatchedSrcEditorRedirectListener"
                  topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
        <listener class="com.github.hoshinofw.multiversion.idea_plugin.MultiversionMoveListener"
                  topic="com.intellij.refactoring.listeners.RefactoringEventListener"/>
    </projectListeners>
</idea-plugin>
